{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Inkwell",
  "identifier": "com.zimakki.inkwell",
  "version": "0.2.13",
  "build": {
    "frontendDist": "frontend"
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/inkwell"],
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "mimeType": "text/markdown",
        "description": "Markdown file"
      }
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["inkwell"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/zimakki/inkwell/releases/latest/download/latest.json"
      ],
      "pubkey": "GENERATE_WITH_npx_tauri_signer_generate"
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Inkwell",
        "width": 900,
        "height": 700,
        "minWidth": 400,
        "minHeight": 300
      }
    ]
  }
}
