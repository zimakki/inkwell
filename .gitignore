# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where third-party dependencies like ExDoc output generated docs.
/doc/

# Temporary files, for example, from tests.
/tmp/

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Ignore package tarball (built via "mix hex.build").
inkwell-*.tar

# Local escript build output.
/inkwell

# Burrito build output.
/burrito_out/

# Superpowers plugin state.
/.superpowers/

# Design specs and internal docs.
/docs/

# Git worktrees.
/.worktrees/

# Tauri
src-tauri/target/
src-tauri/binaries/
src-tauri/gen/
/.expert
.gstack/

# phx.digest fingerprinted + gzipped artifacts (regenerated from the
# tracked priv/static/{app.css,markdown-wide.css,favicon.svg,assets/app.js})
/priv/static/cache_manifest.json
/priv/static/*.gz
/priv/static/*-????????????????????????????????.*
/priv/static/assets/*.gz
/priv/static/assets/*-????????????????????????????????.*
